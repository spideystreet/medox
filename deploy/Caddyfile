{
	order rate_limit before reverse_proxy
}

{$DOMAIN:medoxai.com} {
	# Rate limiting — 30 req/min per IP on API routes
	rate_limit {
		zone api_zone {
			key {remote_host}
			events 30
			window 1m
		}
	}

	# Backend API — proxy to LangGraph server
	handle /api/* {
		rate_limit {
			zone api_zone
		}
		uri strip_prefix /api
		reverse_proxy backend:2024
	}

	# Health check (no rate limit)
	handle /health {
		reverse_proxy backend:2024
	}

	# Frontend — everything else goes to the React SPA
	handle {
		reverse_proxy frontend:3000
	}
}
