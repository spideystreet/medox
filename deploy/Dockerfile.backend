FROM python:3.11-slim

WORKDIR /app

# System deps for psycopg2 and PDF parsing
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency resolution
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files first for caching
COPY pyproject.toml uv.lock ./

# Install production deps — force CPU-only PyTorch from the start to avoid downloading 5GB of CUDA libs
ENV UV_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu
RUN uv sync --frozen --no-dev \
    && rm -rf /root/.cache

# Download embedding model — before COPY src/ so it stays cached across code changes
RUN uv run python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('intfloat/multilingual-e5-base')"

# Copy source code (only this layer rebuilds on code changes)
COPY src/ src/
COPY langgraph.json .
RUN uv sync --frozen --no-dev

EXPOSE 2024

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:2024/ok || exit 1

CMD ["uv", "run", "langgraph", "dev", "--host", "0.0.0.0", "--port", "2024", "--no-browser"]
