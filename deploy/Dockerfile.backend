FROM python:3.11-slim

WORKDIR /app

# System deps for psycopg2 and PDF parsing
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency resolution
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files first for caching
COPY pyproject.toml uv.lock ./

# Install production deps (CPU-only PyTorch to save ~5GB disk)
RUN uv sync --frozen --no-dev \
    && uv pip install --reinstall torch --index-url https://download.pytorch.org/whl/cpu \
    && rm -rf /root/.cache

# Copy source code
COPY src/ src/
COPY langgraph.json .

# Download embedding model at build time so it's cached in the image
RUN uv run python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('intfloat/multilingual-e5-base')"

EXPOSE 2024

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:2024/ok || exit 1

CMD ["uv", "run", "langgraph", "dev", "--host", "0.0.0.0", "--port", "2024", "--no-browser"]
